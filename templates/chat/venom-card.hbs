<div class="cpred-bf-card">
  <div class="card-header">
    {{#if actorImg}}<img src="{{actorImg}}" alt="{{actorName}}" />{{/if}}
    <h3>{{abilityName}}</h3>
  </div>
  <div class="card-body">
    <p><strong>{{actorName}}</strong> strikes with venomous fangs!</p>
    <p>{{description}}</p>
    <p><strong>{{targetName}}</strong> must resist or suffer additional damage.</p>

    <div class="card-buttons">
      <button data-action="cpred-bf-venom-resist"
              data-actor-id="{{actorId}}"
              data-target-id="{{targetId}}"
              class="full-width">
        Roll Resist Torture/Drugs vs DV{{dv}}
      </button>
    </div>
  </div>
</div>
